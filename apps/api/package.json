{
  "name": "@nexus/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "npm run prisma:generate",
    "dev": "tsc-watch --noClear -p tsconfig.build.json --onSuccess \"node dist/apps/api/src/main.js\"",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/apps/api/src/main.js",
    "lint": "eslint .",
    "pretypecheck": "npm run prisma:generate",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prisma:generate": "PRISMA_HIDE_UPDATE_MESSAGE=1 prisma generate",
    "prisma:migrate:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.11",
    "@nestjs/core": "^11.0.11",
    "@nestjs/platform-express": "^11.0.11",
    "@prisma/client": "^6.4.1",
    "dotenv": "^16.6.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/testing": "^11.0.11",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.4",
    "prisma": "^6.4.1",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsc-watch": "^7.2.0",
    "tsx": "^4.19.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.2.4"
  }
}
