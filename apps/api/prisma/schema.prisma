generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model UserSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Integration {
  id          String   @id @default(cuid())
  provider    String
  displayName String
  enabled     Boolean  @default(true)
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Dashboard {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  layout    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
